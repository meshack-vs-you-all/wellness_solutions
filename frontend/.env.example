# Frontend Environment Variables
# Copy this file to .env.local and fill in your values.

# Runtime Mode
VITE_APP_MODE=standalone
VITE_ROUTER_MODE=browser
VITE_APP_BASE_PATH=/

# API Configuration
VITE_API_URL=/wp-json/wellness-solutions/v1
VITE_API_TIMEOUT=30000
VITE_AUTH_SCHEME=Bearer

# Asset / Media URLs
VITE_PUBLIC_ASSET_BASE_URL=
VITE_MEDIA_BASE_URL=

# WordPress Build Output
VITE_BUILD_OUT_DIR=../wordpress/wp-content/themes/wellness-solutions/assets/app

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Public Keys (safe to expose)
VITE_PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxxxx

# Never put sensitive keys in frontend env files.
