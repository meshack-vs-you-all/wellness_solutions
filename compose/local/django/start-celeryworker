#!/bin/bash

set -o errexit
set -o nounset

# Ensure django-filter is installed correctly
pip install django-filter==24.1 --no-cache-dir --force-reinstall

# Set environment variables to prevent watchfiles issues
export WATCHFILES_FORCE_POLLING=true
export CELERY_WORKER_RUNNING=1

# Run celery worker directly without watchfiles
celery -A config.celery_app worker -l INFO
