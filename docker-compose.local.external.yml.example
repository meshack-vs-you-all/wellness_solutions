# Docker Compose Override to Use Existing Services
#
# If you have existing postgres/redis/mailpit containers, use this override:
#   docker-compose -f docker-compose.local.yml -f docker-compose.local.external.yml up
#
# IMPORTANT: Update .envs/.local/.postgres and .envs/.local/.django to match your existing services

version: '3.8'

services:
  django:
    depends_on: []  # Remove postgres/redis/mailpit dependencies
    environment:
      - POSTGRES_HOST=host.docker.internal  # or your Docker host IP
      - REDIS_URL=redis://host.docker.internal:6379/1
      - EMAIL_HOST=host.docker.internal
      - EMAIL_PORT=1025

  # Comment out or remove these services to use existing ones
  postgres:
    profiles: ["disabled"]  # Disable this service

  redis:
    profiles: ["disabled"]  # Disable this service

  mailpit:
    profiles: ["disabled"]  # Disable this service (or keep if you want separate instance)

